# Example configuration for sftpgo-authelia-totp-hook
# Copy this to .env and adjust values as needed

# Required: Authelia base URL
AUTHELIA_BASE_URL=https://authelia.local

# Optional: HTTP server bind address
HTTP_BIND=0.0.0.0:8080

# Optional: HTTP client timeout in milliseconds
HTTP_CLIENT_TIMEOUT_MS=5000

# Optional: Log level (trace, debug, info, warn, error)
LOG_LEVEL=info

# Optional: Allow insecure TLS (development only!)
TLS_INSECURE=false
